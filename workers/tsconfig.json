{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@tomato/*": ["../src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../src/domain/**/*.ts"
  ]
}
