{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "validation_report.schema.json",
  "title": "ValidationReport",
  "description": "Comprehensive validation report combining IO checks and LLM judge verdicts.",
  "type": "object",
  "required": ["step", "timestamp", "overall_result", "io_checks", "llm_checks", "summary"],
  "properties": {
    "step": {
      "type": "string",
      "enum": ["step-2", "step-3"]
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the validation was run."
    },
    "overall_result": {
      "type": "string",
      "enum": ["PASS", "WARN", "FAIL"],
      "description": "PASS = all checks ok, WARN = soft-fails only, FAIL = any hard-fail or IO error."
    },
    "io_checks": {
      "type": "object",
      "required": ["errors", "warnings"],
      "properties": {
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["category", "message"],
            "properties": {
              "category": { "type": "string" },
              "message": { "type": "string" },
              "node_id": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["category", "message"],
            "properties": {
              "category": { "type": "string" },
              "message": { "type": "string" },
              "node_id": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "advisory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "message": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "llm_checks": {
      "type": "object",
      "required": ["per_node"],
      "properties": {
        "per_node": {
          "type": "object",
          "description": "Keyed by node ID (e.g. EP01, EP02A).",
          "additionalProperties": {
            "type": "object",
            "required": ["verdicts", "hard_fails", "soft_fails"],
            "properties": {
              "verdicts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["question_id", "answer", "severity"],
                  "properties": {
                    "question_id": { "type": "string" },
                    "answer": { "type": "boolean" },
                    "reasoning": { "type": "string" },
                    "severity": { "type": "string", "enum": ["hard", "soft"] }
                  },
                  "additionalProperties": false
                }
              },
              "hard_fails": {
                "type": "array",
                "items": { "type": "string" }
              },
              "soft_fails": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": ["total_nodes_checked", "hard_fails", "soft_fails", "io_errors"],
      "properties": {
        "total_nodes_checked": { "type": "integer", "minimum": 0 },
        "hard_fails": { "type": "integer", "minimum": 0 },
        "soft_fails": { "type": "integer", "minimum": 0 },
        "io_errors": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
